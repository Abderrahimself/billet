# billet — local dev environment (12-factor, devops.md P1 "config").
#
# These are THROWAWAY dev-only values. `make up` copies this file to `.env`
# (git-ignored) on first run. Real staging/prod secrets are encrypted in-repo
# with SOPS + age (O5) and land in Phase 2 — never commit plaintext secrets.

# ── PostgreSQL (D5: one instance, 5 databases, one role per service) ────────
# Superuser: admin + healthcheck only. Services NEVER use this role.
POSTGRES_USER=billet_admin
POSTGRES_PASSWORD=dev_admin_pw
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Per-service least-privilege role passwords (consumed by the init script).
AUTH_DB_PASSWORD=dev_auth_pw
CATALOG_DB_PASSWORD=dev_catalog_pw
BOOKING_DB_PASSWORD=dev_booking_pw
PAYMENT_DB_PASSWORD=dev_payment_pw
TICKETS_DB_PASSWORD=dev_tickets_pw

# ── Redis (D6: holds + availability counters) ───────────────────────────────
REDIS_PORT=6379

# ── RabbitMQ (D10: broker for order.paid) ───────────────────────────────────
RABBITMQ_DEFAULT_USER=billet
RABBITMQ_DEFAULT_PASS=dev_rabbit_pw
RABBITMQ_DEFAULT_VHOST=billet
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── MinIO (ticket PDFs; §3.1 tickets). Password must be >= 8 chars. ─────────
MINIO_ROOT_USER=billet
MINIO_ROOT_PASSWORD=dev_minio_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Mailhog (dev SMTP sink; the one MVP transactional email lands here) ─────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ── auth service (D8, §3.1). The DSN is assembled in compose from the ───────
# AUTH_DB_PASSWORD above, so no DB secret is duplicated here. The RS256 signing
# key is a gitignored PEM (make gen-jwt-keys), never a value in this file (O5).
AUTH_PORT=8001
AUTH_JWT_KID=dev-1
AUTH_JWT_ISSUER=billet-auth
AUTH_ACCESS_TOKEN_TTL_SECONDS=900        # 15 min access token (§4)
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000   # 30 d rotating refresh (§4)
AUTH_LOG_LEVEL=INFO
